# Database
MONGODB_URL=mongodb+srv://user:pass@cluster.example.mongodb.net

# Auth (required)
JWT_SECRET=your-access-token-secret
JWT_REFRESH_SECRET=your-refresh-token-secret

# CORS (production) — must match the browser origin exactly (scheme + host, no trailing slash).
# Also used for password-reset email links (must be the customer storefront URL).
FRONTEND_URL=https://your-store.vercel.app
ADMIN_URL=https://your-admin.vercel.app

# Optional: public API URL for Helmet CSP connect-src
BACKEND_URL=https://your-api.vercel.app

# API: routes are mounted at /api/... and /api/v1/... (same handlers; use v1 for new clients).

# Other existing vars (examples)
# PORT=5000
# NODE_ENV=production
# ADMIN_EMAIL=
# ADMIN_PASSWORD=
# ADMIN_JWT_SECRET=
# GOOGLE_CLIENT_ID=
# EMAIL_USER=
# STRIPE_SECRET_KEY=
# RAZORPAY_KEY_ID=
